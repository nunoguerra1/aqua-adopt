// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MarineAnimal {
  id          String         @id @default(cuid())
  name        String
  species     String
  image       String         // URL da foto
  description String         @db.Text
  status      Conservation   @default(STABLE)
  
  // Coordenadas para o Mapa
  latitude    Float
  longitude   Float
  
  // Relações
  updates     StatusUpdate[] // Histórico de saúde/localização
  adoptions   Adoption[]     // Quem "apadrinhou" este animal
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model StatusUpdate {
  id        String       @id @default(cuid())
  title     String       
  content   String       @db.Text
  animalId  String
  animal    MarineAnimal @relation(fields: [animalId], references: [id], onDelete: Cascade)
  
  createdAt DateTime     @default(now())
}

model Adoption {
  id            String       @id @default(cuid())
  adopterName   String
  adopterEmail  String
  animalId      String
  animal        MarineAnimal @relation(fields: [animalId], references: [id])
  
  createdAt     DateTime     @default(now())
}

enum Conservation {
  STABLE
  VULNERABLE
  ENDANGERED
  CRITICAL
}